[
  "<p lang=\"ar\" class=\"ar \"><span class=\"arabic qpc-hafs\">\"عالم الغيب\"</span>، رفع على نعت قوله <span class=\"arabic qpc-hafs\">\"ربي\"</span>،<span class=\"blue\"> وقيل:</span> هو عالم الغيب، <span class=\"arabic qpc-hafs\">\"فلا يظهر\"</span>، لا يطلع، <span class=\"arabic qpc-hafs\">\"على غيبه أحداً\"</span>.</p>"
]